  <diagram name="Correlated Likelihood" id="correlated">
    <mxGraphModel dx="667" dy="466" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c_title" value="JaxPINT — Correlated PTA Likelihood (Two-Tier Woodbury)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="10" width="1320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="c_subtitle" value="pta_logL_correlated — cross-pulsar GWB correlations via ORF; inner woodbury_solve + outer dense Cholesky" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;" parent="1" vertex="1">
          <mxGeometry x="40" y="45" width="1320" height="24" as="geometry" />
        </mxCell>
        <mxCell id="c_lane_inputs" value="Inputs &amp; Shared Signals" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="40" y="70" width="1320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="c_n1" value="CorrelatedPTAConfig&#xa;(pta/correlated_likelihood.py)&#xa;&#xa;toa_data_list, timing_models,&#xa;noise_models,&#xa;signal_injectors,&#xa;correlated_injectors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="110" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="c_n2" value="GlobalParams&#xa;+ tuple[ParameterVector]&#xa;&#xa;shared PTA params&#xa;+ per-pulsar params" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="320" y="110" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="c_n3" value="SignalInjectors (optional)&#xa;(pta/likelihood.py)&#xa;&#xa;CWInjector, CURNInjector, ...&#xa;&#xa;per-pulsar external_delay&#xa;and external (U, Phi)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="110" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="c_n4" value="HDCorrelatedGWBInjector&#xa;(pta/signals/correlated_gwb.py)&#xa;&#xa;get_fourier_basis → F_p&#xa;get_psd → S  (n_basis)&#xa;get_orf_matrix → Γ  (n_psr × n_psr)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="840" y="110" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="c_lane_inner" value="Inner Tier — per-pulsar Woodbury   (woodbury_dot, woodbury_solve from jaxpint.utils)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="50" y="270" width="1320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="c_n5" value="Per-pulsar setup (for each p)&#xa;&#xa;r_p = residuals(TimingModel_p, params_p)&#xa;        − external_delay_p&#xa;&#xa;(Ndiag, U, Phi)_p = NoiseModel_p.covariance&#xa;        ⊕  external (U_ext, Phi_ext)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="310" width="320" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_n6" value="_per_pulsar_intermediates&#xa;(pta/correlated_likelihood.py)&#xa;&#xa;rCr_p, logdetC_p  ←  woodbury_dot(·, r_p, r_p)&#xa;Cinv_r, Cinv_F    ←  woodbury_solve(·, [r_p | F_p])&#xa;z_p = F_p^T · Cinv_r           ∈ ℝ^{n_basis}&#xa;D_p = F_p^T · Cinv_F           ∈ ℝ^{n_basis × n_basis}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="490" y="310" width="480" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_n7" value="Per-pulsar outputs&#xa;&#xa;rCr_p ,  logdetC_p&#xa;z_p  ∈ ℝ^{n_basis}&#xa;D_p  ∈ ℝ^{n_basis × n_basis}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1050" y="310" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_lane_outer" value="Outer Tier — cross-pulsar Cholesky   (jax.scipy.linalg.cho_factor / cho_solve)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontStyle=1;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="40" y="490" width="1320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="c_n8" value="Φ_gwb  =  Γ ⊗ diag(S)&#xa;&#xa;Φ_gwb^{−1}  =  Γ^{−1} ⊗ diag(1/S)&#xa;&#xa;shape:  (n_psr · n_basis)²" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="60" y="540" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="c_n9" value="Σ_gwb  =  Φ_gwb^{−1}  +  blockdiag(D_1, …, D_n)&#xa;&#xa;z  =  concat(z_1, …, z_n)&#xa;&#xa;(compressed Fourier system&#xa;couples all pulsars via Γ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="330" y="540" width="280" height="160" as="geometry" />
        </mxCell>
